{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "outputDirectory": "out",
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.qicore.ai"
        }
      ],
      "destination": "https://qicore.ai/:path*",
      "permanent": true
    }
  ]
}
